    classDef rendererLayer fill:#1e40af,stroke:#3b82f6,color:#fff
    classDef ipcLayer fill:#b45309,stroke:#f59e0b,color:#fff
    classDef teamLayer fill:#065f46,stroke:#10b981,color:#fff
    classDef agentosLayer fill:#7c2d12,stroke:#f97316,color:#fff
    classDef securityLayer fill:#991b1b,stroke:#ef4444,color:#fff
    classDef dataLayer fill:#1e293b,stroke:#64748b,color:#fff
    classDef externalLayer fill:#4c1d95,stroke:#8b5cf6,color:#fff
